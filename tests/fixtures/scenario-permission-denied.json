{
  "events": [
    { "type": "system", "subtype": "init", "session_id": "$SID", "cwd": "$CWD", "permissionMode": "default" }
  ],
  "turns": [
    {
      "on": { "type": "prompt" },
      "emit": [
        { "type": "stream_event", "event": { "type": "message_start", "message": { "id": "msg_p", "role": "assistant" } } },
        { "type": "stream_event", "event": { "type": "content_block_start", "index": 0, "content_block": { "type": "tool_use", "id": "tu_w", "name": "Write", "input": {} } } },
        { "type": "stream_event", "event": { "type": "content_block_delta", "index": 0, "delta": { "type": "input_json_delta", "partial_json": "{\"file_path\":\"/tmp/hello.txt\",\"content\":\"Hello\"}" } } },
        { "type": "stream_event", "event": { "type": "content_block_stop", "index": 0 } },
        { "type": "user", "message": { "role": "user", "content": [ { "type": "tool_result", "tool_use_id": "tu_w", "content": "Claude requested permissions to write to /tmp/hello.txt, but you haven't granted it yet.", "is_error": true } ] } }
      ]
    },
    {
      "on": { "type": "control", "subtype": "interrupt" },
      "emit": [
        { "type": "stream_event", "event": { "type": "message_stop" } },
        { "type": "result", "subtype": "error_during_execution", "stop_reason": "interrupted", "duration_ms": 5, "total_cost_usd": 0.0, "is_error": true,
          "permission_denials": [{"tool_name":"Write","tool_use_id":"tu_w","tool_input":{"file_path":"/tmp/hello.txt","content":"Hello"}}] }
      ]
    }
  ]
}
