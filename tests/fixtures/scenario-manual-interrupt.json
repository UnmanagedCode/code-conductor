{
  "events": [
    { "type": "system", "subtype": "init", "session_id": "$SID", "cwd": "$CWD", "permissionMode": "$MODE" }
  ],
  "turns": [
    {
      "on": { "type": "prompt" },
      "delay_ms": 25,
      "emit": [
        { "type": "stream_event", "event": { "type": "message_start", "message": { "id": "msg_w", "role": "assistant" } } },
        { "type": "stream_event", "event": { "type": "content_block_start", "index": 0, "content_block": { "type": "text", "text": "" } } },
        { "type": "stream_event", "event": { "type": "content_block_delta", "index": 0, "delta": { "type": "text_delta", "text": "Working on this longer task" } } }
      ]
    },
    {
      "on": { "type": "control", "subtype": "interrupt" },
      "emit": [
        { "type": "stream_event", "event": { "type": "content_block_stop", "index": 0 } },
        { "type": "stream_event", "event": { "type": "content_block_start", "index": 1, "content_block": { "type": "text", "text": "" } } },
        { "type": "stream_event", "event": { "type": "content_block_delta", "index": 1, "delta": { "type": "text_delta", "text": "[Request interrupted by user]" } } },
        { "type": "stream_event", "event": { "type": "content_block_stop", "index": 1 } },
        { "type": "stream_event", "event": { "type": "message_stop" } },
        { "type": "result", "subtype": "error_during_execution", "stop_reason": "interrupted", "duration_ms": 5, "total_cost_usd": 0.0, "is_error": true }
      ]
    }
  ]
}
