{
  "events": [
    { "type": "system", "subtype": "init", "session_id": "$SID", "cwd": "$CWD", "permissionMode": "$MODE", "uuid": "init-uuid" }
  ],
  "turns": [
    {
      "on": { "type": "prompt" },
      "emit": [
        { "type": "stream_event", "event": { "type": "message_start", "message": { "id": "msg_x", "role": "assistant" } }, "uuid": "stream-1" },
        { "type": "stream_event", "event": { "type": "content_block_start", "index": 0, "content_block": { "type": "text", "text": "" } }, "uuid": "stream-2" },
        { "type": "stream_event", "event": { "type": "content_block_delta", "index": 0, "delta": { "type": "text_delta", "text": "ok" } }, "uuid": "stream-3" },
        { "type": "stream_event", "event": { "type": "content_block_stop", "index": 0 }, "uuid": "stream-4" },
        { "type": "stream_event", "event": { "type": "message_stop" }, "uuid": "stream-5" },
        { "type": "assistant", "message": { "id": "msg_x", "role": "assistant", "content": [{ "type": "text", "text": "ok" }] }, "uuid": "assistant-leaf-uuid" },
        { "type": "result", "subtype": "success", "stop_reason": "end_turn", "duration_ms": 10, "total_cost_usd": 0.0001, "is_error": false, "uuid": "result-uuid" }
      ]
    }
  ]
}
