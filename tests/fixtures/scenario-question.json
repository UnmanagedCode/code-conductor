{
  "events": [
    { "type": "system", "subtype": "init", "session_id": "$SID", "cwd": "$CWD", "permissionMode": "$MODE" }
  ],
  "turns": [
    {
      "on": { "type": "prompt" },
      "emit": [
        { "type": "stream_event", "event": { "type": "message_start", "message": { "id": "msg_q", "role": "assistant" } } },
        { "type": "stream_event", "event": { "type": "content_block_start", "index": 0, "content_block": { "type": "tool_use", "id": "tu_q", "name": "AskUserQuestion", "input": {} } } },
        { "type": "stream_event", "event": { "type": "content_block_delta", "index": 0, "delta": { "type": "input_json_delta", "partial_json": "{\"questions\":[{\"question\":\"Pick a fruit\",\"header\":\"Fruit\",\"multiSelect\":false,\"options\":[{\"label\":\"Apple\"},{\"label\":\"Banana\"}]}]}" } } },
        { "type": "stream_event", "event": { "type": "content_block_stop", "index": 0 } },
        { "type": "user", "message": { "role": "user", "content": [ { "type": "tool_result", "tool_use_id": "tu_q", "content": "Answer questions?", "is_error": true } ] } },
        { "type": "stream_event", "event": { "type": "message_stop" } },
        { "type": "result", "subtype": "success", "stop_reason": "end_turn", "duration_ms": 5, "total_cost_usd": 0.0, "is_error": false }
      ]
    },
    {
      "on": { "type": "prompt" },
      "emit": [
        { "type": "stream_event", "event": { "type": "message_start", "message": { "id": "msg_after", "role": "assistant" } } },
        { "type": "stream_event", "event": { "type": "content_block_start", "index": 0, "content_block": { "type": "text", "text": "" } } },
        { "type": "stream_event", "event": { "type": "content_block_delta", "index": 0, "delta": { "type": "text_delta", "text": "got it" } } },
        { "type": "stream_event", "event": { "type": "content_block_stop", "index": 0 } },
        { "type": "stream_event", "event": { "type": "message_stop" } },
        { "type": "result", "subtype": "success", "stop_reason": "end_turn", "duration_ms": 5, "total_cost_usd": 0.0, "is_error": false }
      ]
    }
  ]
}
