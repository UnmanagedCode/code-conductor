{
  "events": [
    { "type": "system", "subtype": "init", "session_id": "$SID", "cwd": "$CWD", "model": "claude-sonnet-4-6", "permissionMode": "$MODE", "tools": [], "uuid": "dw-init-1" }
  ],
  "turns": [
    {
      "on": { "type": "prompt", "text": "start slow" },
      "delay_ms": 40,
      "emit": [
        { "type": "stream_event", "event": { "type": "message_start", "message": { "id": "msg_dw1", "role": "assistant" } } },
        { "type": "stream_event", "event": { "type": "content_block_start", "index": 0, "content_block": { "type": "text", "text": "" } } },
        { "type": "stream_event", "event": { "type": "content_block_delta", "index": 0, "delta": { "type": "text_delta", "text": "working..." } } }
      ]
    },
    {
      "on": { "type": "control", "subtype": "interrupt" },
      "emit": [
        { "type": "stream_event", "event": { "type": "content_block_stop", "index": 0 } },
        { "type": "stream_event", "event": { "type": "message_stop" } },
        { "type": "result", "subtype": "error_during_execution", "stop_reason": "interrupted", "duration_ms": 40, "total_cost_usd": 0.0001, "is_error": true }
      ]
    },
    {
      "on": { "type": "prompt", "text": "explicit follow" },
      "emit": [
        { "type": "stream_event", "event": { "type": "message_start", "message": { "id": "msg_dw2", "role": "assistant" } } },
        { "type": "stream_event", "event": { "type": "content_block_start", "index": 0, "content_block": { "type": "text", "text": "" } } },
        { "type": "stream_event", "event": { "type": "content_block_delta", "index": 0, "delta": { "type": "text_delta", "text": "done" } } },
        { "type": "stream_event", "event": { "type": "content_block_stop", "index": 0 } },
        { "type": "stream_event", "event": { "type": "message_stop" } },
        { "type": "result", "subtype": "success", "stop_reason": "end_turn", "duration_ms": 50, "total_cost_usd": 0.0001, "is_error": false }
      ]
    }
  ]
}
