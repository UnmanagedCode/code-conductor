{
  "events": [
    { "type": "system", "subtype": "init", "session_id": "$SID", "cwd": "$CWD", "permissionMode": "$MODE" }
  ],
  "turns": [
    {
      "on": { "type": "prompt" },
      "emit": [
        { "type": "stream_event", "event": { "type": "message_start", "message": { "id": "msg_p", "role": "assistant" } } },
        { "type": "stream_event", "event": { "type": "content_block_start", "index": 0, "content_block": { "type": "tool_use", "id": "tu_ask", "name": "Bash", "input": {} } } },
        { "type": "stream_event", "event": { "type": "content_block_delta", "index": 0, "delta": { "type": "input_json_delta", "partial_json": "{\"command\":\"rm -rf /\"}" } } },
        { "type": "stream_event", "event": { "type": "content_block_stop", "index": 0 } },
        { "type": "control_request", "request_id": "perm-1", "request": { "subtype": "can_use_tool", "tool_name": "Bash", "input": { "command": "rm -rf /" }, "title": "Confirm dangerous command", "displayName": "Bash" } }
      ]
    },
    {
      "on": { "type": "control_response", "request_id": "perm-1", "behavior": "allow" },
      "emit": [
        { "type": "user", "message": { "role": "user", "content": [ { "type": "tool_result", "tool_use_id": "tu_ask", "content": "(simulated execution)", "is_error": false } ] } },
        { "type": "stream_event", "event": { "type": "message_stop" } },
        { "type": "result", "subtype": "success", "stop_reason": "end_turn", "duration_ms": 5, "total_cost_usd": 0.0, "is_error": false }
      ]
    },
    {
      "on": { "type": "control_response", "request_id": "perm-1", "behavior": "deny" },
      "emit": [
        { "type": "user", "message": { "role": "user", "content": [ { "type": "tool_result", "tool_use_id": "tu_ask", "content": "denied by user", "is_error": true } ] } },
        { "type": "stream_event", "event": { "type": "message_stop" } },
        { "type": "result", "subtype": "success", "stop_reason": "end_turn", "duration_ms": 5, "total_cost_usd": 0.0, "is_error": false }
      ]
    }
  ]
}
